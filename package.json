{
  "name": "@apmg/vertical-video-carousel",
  "description": "A themeable, framework-agnostic vertical (short-form) video carousel, with a React wrapper, for use across APM sites and apps.",
  "version": "0.1.0",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./element": {
      "types": "./dist/element.d.ts",
      "import": "./dist/element.esm.js",
      "require": "./dist/element.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "keywords": [
    "video",
    "carousel",
    "react",
    "web-component",
    "apmg",
    "media"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/APMG/apm-vv.git"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json && rollup -c",
    "dev": "rollup -c -w",
    "test": "jest --watch",
    "test:ci": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "eslint": "eslint src",
    "eslint:fix": "eslint src --fix",
    "prettier": "prettier --check 'src/**/*.{ts,tsx}'",
    "prettier:fix": "prettier --check 'src/**/*.{ts,tsx}' --write",
    "clean": "rimraf node_modules dist"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn eslint && yarn prettier",
      "pre-push": "yarn eslint && yarn prettier && yarn test:ci"
    }
  },
  "peerDependencies": {
    "react": "^17 || ^18",
    "react-dom": "^17 || ^18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.6",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.5",
    "rollup": "^4.14.3",
    "ts-jest": "^29.1.2",
    "tslib": "^2.8.1",
    "typescript": "^5.4.5"
  }
}
